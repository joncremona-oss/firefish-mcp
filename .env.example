# Firefish MCP Server — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Firefish OAuth credentials (from Firefish → Settings → Integrations → API)
FIREFISH_CLIENT_ID=your_client_id_here
FIREFISH_CLIENT_SECRET=your_client_secret_here

# Firefish API base URL (do not change unless Firefish tells you to)
FIREFISH_API_URL=https://api.firefishsoftware.com

# Port for the MCP server (Railway/Render will set this automatically)
PORT=3000
